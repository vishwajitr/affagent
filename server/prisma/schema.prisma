generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  NOT_CALLED
  CALLED
  INTERESTED
  NOT_INTERESTED
  NO_ANSWER
  FAILED
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  FAILED
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  password     String
  // Per-user Twilio credentials (user brings their own account)
  twilioSid    String?
  twilioToken  String?
  twilioPhone  String?
  createdAt    DateTime   @default(now())
  contacts     Contact[]
  campaigns    Campaign[]
}

model Contact {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  status       ContactStatus @default(NOT_CALLED)
  lastResponse String?
  retryCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  calls        Call[]

  @@unique([userId, phone])
  @@index([userId, status])
}

model Campaign {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  script    String   @db.Text
  createdAt DateTime @default(now())
  calls     Call[]

  @@index([userId])
}

model Call {
  id         String     @id @default(cuid())
  contactId  String
  campaignId String
  callSid    String?    @unique
  callStatus CallStatus @default(INITIATED)
  userInput  String?
  duration   Int?
  createdAt  DateTime   @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([campaignId])
  @@index([callSid])
}
